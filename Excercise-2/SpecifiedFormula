using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace SpecifiedFormula
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Write("Enter first number (x): ");
            double x = double.Parse(Console.ReadLine());
            Console.Write("Enter second number (y): ");
            double y = double.Parse(Console.ReadLine());
            Console.Write("Enter third number (z): ");
            double z = double.Parse(Console.ReadLine());

            double answer1 = (x + y) * z;
            double answer2 = x * y + y * z;

            Console.WriteLine($"(x+y).z = {answer1}");
            Console.WriteLine($"x.y + y.z = {answer2}");

            Console.ReadLine();
        }
    }
}
